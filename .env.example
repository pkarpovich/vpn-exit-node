# vpn-exit-node configuration. Copy to .env and fill in:
#   cp .env.example .env
# .env is gitignored - never commit real keys or VPN credentials.

# =============================================================================
# Core Tailscale (required for every mode)
# =============================================================================

# Tailscale auth key. Generate at:
#   https://login.tailscale.com/admin/settings/keys
# Prefer a reusable key (all keys expire, 90 days max), or an OAuth client
# secret for non-expiring credentials on a long-lived node. Tag it (e.g.
# tag:exit-node) so autoApprovers can approve the route. OAuth path needs
# ?ephemeral=false on the secret plus --advertise-tags in TS_EXTRA_ARGS - see
# "Auth keys / key expiry" in the README.
TS_AUTHKEY=

# Node name on the tailnet (also the Docker container name). Unique per box.
TS_HOSTNAME=vpn-exit-node

# Extra `tailscale up` args. Keep --advertise-exit-node for exit-node modes.
TS_EXTRA_ARGS=--advertise-exit-node

# =============================================================================
# SOCKS5 (mode 1, selective - only when started with `make up-socks`)
# =============================================================================

# Port the SOCKS5 proxy listens on. Bound to the 100.x tailnet address only.
SOCKS_PORT=1080

# Optional SOCKS5 auth. Leave both blank for unauthenticated (tailnet-only)
# access; set both to require a username/password.
SOCKS_USER=
SOCKS_PASS=

# Advanced (rarely needed) SOCKS entrypoint overrides with their defaults:
#   TS_IFACE=tailscale0        interface to read the 100.x address from
#   SOCKS_WAIT_RETRIES=60      2s polls to wait for the tailnet IPv4

# =============================================================================
# VPN egress via gluetun (mode 3 - only with compose.vpn.yml / `make up-vpn`)
# =============================================================================

# gluetun provider, e.g. mullvad, nordvpn, protonvpn, ... or `custom`.
# Full provider list and options: https://github.com/qdm12/gluetun-wiki
VPN_SERVICE_PROVIDER=

# Tunnel protocol: openvpn (default) or wireguard.
VPN_TYPE=openvpn

# Target egress country, provider-dependent, e.g. "Netherlands".
SERVER_COUNTRIES=

# --- OpenVPN credentials (VPN_TYPE=openvpn) ---
OPENVPN_USER=
OPENVPN_PASSWORD=
# For VPN_SERVICE_PROVIDER=custom, point to a .ovpn mounted under ./vpn-files,
# e.g. /gluetun/custom/myconfig.ovpn
OPENVPN_CUSTOM_CONFIG=

# --- WireGuard credentials (VPN_TYPE=wireguard) ---
WIREGUARD_PRIVATE_KEY=
WIREGUARD_ADDRESSES=

# LAN subnets the box may reach BYPASSING the VPN (comma-separated), e.g.
# 192.168.1.0/24. Leave empty otherwise. Do NOT put the tailnet range
# (100.64.0.0/10) here: it is an OUTPUT-chain allowance that misses the exit
# node's forwarded return traffic and installs a priority-99 route that
# black-holes replies. The return path is fixed by the route-fix sidecar in
# compose.vpn.yml. Never set FIREWALL=off.
FIREWALL_OUTBOUND_SUBNETS=

# Container timezone (affects gluetun log timestamps).
TZ=UTC
